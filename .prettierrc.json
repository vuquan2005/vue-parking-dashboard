{
  "$schema": "https://json.schemastore.org/prettierrc",
  "semi": false,
  "singleQuote": true,
  "printWidth": 90,
  "tabWidth": 2,
  "overrides": [
    {
      "files": ["*.js", "*.mjs", "*.cjs", "*.ts", "*.mts", "*.cts"],
      "options": {
        "tabWidth": 4
      }
    },
    {
      "files": ["*.md"],
      "options": {
        "proseWrap": "preserve",
        "printWidth": 999
      }
    }
  ]
}
